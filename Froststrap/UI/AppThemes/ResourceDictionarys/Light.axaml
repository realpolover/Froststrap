<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="NewTextEditorBackground"       Color="White" />
    <SolidColorBrush x:Key="NewTextEditorForeground"       Color="#2D2D2D" />
    <SolidColorBrush x:Key="NewTextEditorLink"             Color="#FF51A2ED" />
    <SolidColorBrush x:Key="CompletionListBackgroundBrush" Color="#F2F2F2" />

    <SolidColorBrush x:Key="PrimaryBackgroundColor"        Color="#B3FFFFFF" />
    <SolidColorBrush x:Key="NormalDarkAndLightBackground"  Color="#B3FFFFFF" />

    <SolidColorBrush x:Key="ApplicationBackgroundColor"    Color="#01F3F3F3" />

    <SolidColorBrush x:Key="NotificationBackgroundColor"   Color="#F3F3F3" />

	<Bitmap x:Key="Icon_Plus">avares://Froststrap/Resources/SideNav/Plus_Dark.png</Bitmap>
	<Bitmap x:Key="Icon_Play">avares://Froststrap/Resources/SideNav/Play_Dark.png</Bitmap>
	<Bitmap x:Key="Icon_Gamepad2">avares://Froststrap/Resources/SideNav/Gamepad2_Dark.png</Bitmap>
	<Bitmap x:Key="Icon_HardDriveUpload">avares://Froststrap/Resources/SideNav/HardDriveUpload_Dark.png</Bitmap>
	<Bitmap x:Key="Icon_BookOpen">avares://Froststrap/Resources/SideNav/BookOpen_Dark.png</Bitmap>
	<Bitmap x:Key="Icon_Palette">avares://Froststrap/Resources/SideNav/Palette_Dark.png</Bitmap>
	<Bitmap x:Key="Icon_Flag">avares://Froststrap/Resources/SideNav/Flag_Dark.png</Bitmap>
	<Bitmap x:Key="Icon_PenLine">avares://Froststrap/Resources/SideNav/PenLine_Dark.png</Bitmap>
	<Bitmap x:Key="Icon_Settings">avares://Froststrap/Resources/SideNav/Settings_Dark.png</Bitmap>
	<Bitmap x:Key="Icon_Globe">avares://Froststrap/Resources/SideNav/Globe_Dark.png</Bitmap>
	<Bitmap x:Key="Icon_Link2">avares://Froststrap/Resources/SideNav/Link2_Dark.png</Bitmap>
	<Bitmap x:Key="Icon_Info">avares://Froststrap/Resources/SideNav/Info_Dark.png</Bitmap>
</ResourceDictionary>