<UserControl x:Class="Froststrap.UI.Elements.Settings.Pages.FastFlags.FastFlagEditor"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ic="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
             xmlns:lucideEnums="clr-namespace:LucideAvalonia.Enum;assembly=LucideAvalonia"
             xmlns:resources="using:Froststrap.Resources"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:model="clr-namespace:Froststrap.Models"
             xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             Focusable="True"
             mc:Ignorable="d">

    <Grid DragDrop.AllowDrop="True"
          DragDrop.Drop="OnDrop"
          DragDrop.DragEnter="OnDragEnter"
          DragDrop.DragLeave="OnDragLeave"
          Background="Transparent">

        <Grid RowDefinitions="Auto, Auto, Auto, *" Margin="14">

            <ui:FAInfoBar Grid.Row="0"
                          Message="{x:Static resources:Strings.Menu_FastFlagEditor_WhiteList}"
                          Severity="Informational"
                          IsOpen="True"
                          IsClosable="False"
                          Margin="0,4,0,8" />

            <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,0">
                <controls:IconButton Click="AddButton_Click" Icon="Plus" Content="{x:Static resources:Strings.Menu_FastFlagEditor_AddNew}" Margin="0,0,8,8" />
                <controls:IconButton Click="DeleteButton_Click" Icon="Trash2" Classes="Danger" Content="{x:Static resources:Strings.Menu_FastFlagEditor_DeleteSelected}" Margin="0,0,8,8" x:Name="DeleteSelectedButton" IsEnabled="False" />
                <controls:IconButton Click="DeleteAllButton_Click" Icon="Trash" Content="{x:Static resources:Strings.Common_DeleteAll}" Margin="0,0,8,8" />
                <controls:IconButton Click="CopyJSONButton_Click" Icon="Clipboard" Content="{x:Static resources:Strings.Common_CopyAll}" Margin="0,0,8,8" />
                <controls:IconButton Click="ExportJSONButton_Click" Icon="ArrowRightFromLine" Content="{x:Static resources:Strings.Menu_FastFlagEditor_ExportJson}" Margin="0,0,8,8" />
                <controls:IconButton Click="FlagProfiles_Click" Icon="FilePenLine" Content="{x:Static resources:Strings.Common_Profiles}" Margin="0,0,8,8" />
                <controls:IconButton Click="CleanListButton_Click" Icon="Funnel" Content="{x:Static resources:Strings.Menu_FastFlagEditor_CleanList}" Margin="0,0,8,8" />

                <ToggleButton Name="TogglePresetsButton"
                              Click="ToggleButton_Click"
                              Content="{x:Static resources:Strings.Menu_FastFlagEditor_ShowPresetFlags}"
                              IsChecked="False"
                              VerticalAlignment="Center"
                              Margin="0,0,8,8"/>
            </WrapPanel>

            <Grid Grid.Row="2" RowDefinitions="Auto, Auto" Margin="0,0,1,4">
                <TextBlock x:Name="TotalFlagsTextBlock"
                           Grid.Row="0"
                           HorizontalAlignment="Right"
                           Margin="0,0,8,8"
                           FontWeight="Medium"
                           FontSize="12"
                           Text="{x:Static resources:Strings.Menu_FastFlagEditor_TotalFlags}" />

                <Grid Grid.Row="1">
                    <TextBox Name="SearchTextBox"
                             VerticalContentAlignment="Center"
                             PlaceholderText="{x:Static resources:Strings.Common_Search}"
                             TextChanged="SearchTextBox_TextChanged">
                        <TextBox.InnerLeftContent>
                            <ic:Lucide Height="16" Width="16" Icon="Search" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </TextBox.InnerLeftContent>
                    </TextBox>

                    <TextBlock x:Name="SuggestionTextBlock"
                               Cursor="Hand"
                               PointerPressed="SuggestionTextBlock_PointerPressed"
                               Margin="12,0,11,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="#FF51A2ED"
                               Opacity="0"
                               IsVisible="False">
                        <Run Text="Looking for " />
                        <Run x:Name="SuggestionKeywordRun" Text="" FontWeight="Bold" />
                        <Run Text="?" />
                    </TextBlock>
                </Grid>
            </Grid>

            <Grid Grid.Row="3">
                <DataGrid Name="DataGrid"
                          AutoGenerateColumns="False"
                          SelectionChanged="DataGrid_SelectionChanged"
                          CanUserResizeColumns="True"
                          CellEditEnding="DataGrid_CellEditEnding"
                          HorizontalScrollBarVisibility="Disabled"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="All"
                          x:DataType="model:FastFlag">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn MinWidth="67"
                                                Width="Auto"
                                                Header="{x:Static resources:Strings.Common_Presets}"
                                                CanUserResize="False"
                                                IsVisible="{Binding #TogglePresetsButton.IsChecked}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="model:FastFlag">
                                    <ic:Lucide Height="20" Width="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Width="*"
                                            Binding="{Binding Name}"
                                            Header="{x:Static resources:Strings.Common_Name}"
                                            x:DataType="model:FastFlag" />

                        <DataGridTextColumn Width="250"
                                            Binding="{Binding Value}"
                                            Header="{x:Static resources:Strings.Common_Value}"
                                            x:DataType="model:FastFlag" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock x:Name="EmptyTextBlock"
                           Text="{x:Static resources:Strings.Menu_FastFlagEditor_NoFlags}"
                           FontSize="16"
                           FontWeight="Medium"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           IsVisible="False"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextAlignment="Center"/>
            </Grid>
        </Grid>

        <Grid x:Name="DragOverlay"
              IsHitTestVisible="False"
              IsVisible="False"
              Background="#88000000">

            <TextBlock Text="{x:Static resources:Strings.Menu_FastFlagEditor_DragOverlay}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <Grid>
                <Path Stroke="{DynamicResource AccentButtonBackground}"
                      StrokeThickness="3"
                      StrokeJoin="Round"
                      Data="M 0,0 L 30,0 M 0,0 L 0,30"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="10,10,0,0" />

                <Path Stroke="{DynamicResource AccentButtonBackground}"
                      StrokeThickness="3"
                      StrokeJoin="Round"
                      Data="M 30,0 L 0,0 M 30,0 L 30,30"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,10,10,0" />

                <Path Stroke="{DynamicResource AccentButtonBackground}"
                      StrokeThickness="3"
                      StrokeJoin="Round"
                      Data="M 0,30 L 30,30 M 0,30 L 0,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Margin="10,0,0,10" />

                <Path Stroke="{DynamicResource AccentButtonBackground}"
                      StrokeThickness="3"
                      StrokeJoin="Round"
                      Data="M 30,30 L 0,30 M 30,30 L 30,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,10,10" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>