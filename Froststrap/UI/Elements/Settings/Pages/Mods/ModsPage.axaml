<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:Froststrap.Models"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:Froststrap.UI.ViewModels.Settings.Mods"
             xmlns:controls="using:Froststrap.UI.Elements.Controls"
             xmlns:conv="using:Avalonia.Data.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Froststrap.UI.Elements.Settings.Pages.Mods.ModsPage"
             x:DataType="vm:ModsViewModel"
             DragDrop.AllowDrop="True">

    <Grid>

        <Grid RowDefinitions="Auto, *, Auto"
              Margin="14"
              Background="Transparent"
              DragDrop.AllowDrop="True"
              DragDrop.Drop="Page_Drop"
              DragDrop.DragEnter="Page_DragEnter"
              DragDrop.DragLeave="Page_DragLeave">

            <StackPanel Grid.Row="0">
                <Grid ColumnDefinitions="*,*,*">
                    <controls:CardAction Grid.Column="0" Margin="0,0,4,0" Header="Community Mods"
                                         Icon="ShoppingStore" Description="Explore user-created mods."
                                         Command="{Binding OpenCommunityModsCommand}" />
                    <controls:CardAction Grid.Column="1" Margin="2,0,2,0" Header="Preset Mods"
                                         Icon="BookOpen" Description="Official built-in mods."
                                         Command="{Binding OpenPresetModsCommand}" />
                    <controls:CardAction Grid.Column="2" Margin="4,0,0,0" Header="Mod Generator"
                                         Icon="PaintBrush" Description="Generate mods easily with a single click."
                                         Command="{Binding OpenModGeneratorCommand}" />
                </Grid>

                <Separator Margin="0,8" />

                <ui:InfoBar Message="Import mods by dragging the mod or importing, mods with lower priority get applied last making it win conflicts with other mods."
                            Severity="Informational"
                            IsOpen="True"
                            Margin="0,4"
                            IsClosable="False" />

                <controls:IconButton Icon="Add"
                                     Content="Add new mod"
                                     HorizontalAlignment="Stretch"
                                     Command="{Binding AddModCommand}"
                                     Margin="0,4" />

                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                    <controls:IconButton Icon="Folder"
                                         Content="Import Folder"
                                         HorizontalAlignment="Stretch"
                                         Margin="0,0,4,0"
                                         Command="{Binding ImportFolderCommand}"
                                         CommandParameter="{Binding $self}" />
                    <controls:IconButton Icon="FolderZip"
                                         Content="Import ZIP"
                                         HorizontalAlignment="Stretch"
                                         Margin="4,0,0,0"
                                         Grid.Column="1"
                                         Command="{Binding ImportZipCommand}"
                                         CommandParameter="{Binding $self}" />
                </Grid>
            </StackPanel>

            <Grid Grid.Row="1" ColumnDefinitions="2*, 1*" Margin="0,8,0,0"
                  IsVisible="{Binding HasMods}">

                <Border Grid.Column="0" Padding="0,0,8,0">
                    <ListBox x:Name="ModsListBox"
                             ItemsSource="{Binding Modifications}"
                             SelectedItem="{Binding SelectedMod}"
                             Background="{DynamicResource ControlFillColorSecondaryBrush}"
                             BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                             BorderThickness="1"
                             CornerRadius="6">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ModConfig}">
                                <Border Margin="4" Padding="8" CornerRadius="4"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <controls:IconButton Grid.Row="0" Grid.Column="0"
                                                             Icon="ArrowUp"
                                                             Margin="0,0,4,0"
                                                             VerticalAlignment="Center"
                                                             ToolTip.Tip="Move up"
                                                             Command="{Binding ((vm:ModsViewModel)DataContext).MoveUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                             CommandParameter="{Binding}" />
                                        <controls:IconButton Grid.Row="0" Grid.Column="1"
                                                             Icon="ArrowDown"
                                                             Margin="0,0,4,0"
                                                             VerticalAlignment="Center"
                                                             ToolTip.Tip="Move down"
                                                             Command="{Binding ((vm:ModsViewModel)DataContext).MoveDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                             CommandParameter="{Binding}" />

                                        <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="4,0">
                                            <TextBlock Text="{Binding FolderName}"
                                                       FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Priority, StringFormat='{}Priority: {0}'}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Text="{Binding FileCount, StringFormat='{}{0} Files'}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <ToggleSwitch Grid.Row="0" Grid.Column="3"
                                                      IsChecked="{Binding Enabled}"
                                                      Margin="8,0"
                                                      VerticalAlignment="Center" />

                                        <ComboBox Grid.Row="0" Grid.Column="4"
                                                  MinWidth="80"
                                                  Margin="4,0,0,0"
                                                  ItemsSource="{x:Static vm:ModsViewModel.TargetOptions}"
                                                  SelectedItem="{Binding Target}"
                                                  VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListBox.Styles>
                    </ListBox>
                </Border>

                <Border Grid.Column="1" Padding="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Selected mod actions" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <StackPanel IsEnabled="{Binding SelectedMod, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
                            <TextBox Watermark="New name"
                                     Text="{Binding NewName}"
                                     Margin="0,4" />
                            <controls:IconButton Icon="Edit"
                                                 Content="Rename"
                                                 Command="{Binding RenameModCommand}"
                                                 HorizontalAlignment="Stretch"
                                                 Margin="0,4" />

                            <Grid ColumnDefinitions="*,*" Margin="0,4">
                                <controls:IconButton Grid.Column="0"
                                                     Icon="Delete"
                                                     Content="Delete"
                                                     Classes="Danger"
                                                     Command="{Binding DeleteModCommand}"
                                                     CommandParameter="{Binding SelectedMod}"
                                                     HorizontalAlignment="Stretch"
                                                     Margin="0,0,2,0" />
                                <controls:IconButton Grid.Column="1"
                                                     Icon="Folder"
                                                     Content="Open Folder"
                                                     Command="{Binding OpenModFolderCommand}"
                                                     CommandParameter="{Binding SelectedMod}"
                                                     HorizontalAlignment="Stretch"
                                                     Margin="2,0,0,0" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                  IsVisible="{Binding !HasMods}">
                <TextBlock Text="No mods installed."
                           FontSize="20"
                           Opacity="0.5"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>
        </Grid>

        <Grid IsHitTestVisible="False"
              IsVisible="{Binding IsDragOver}"
              Background="#88000000">

            <TextBlock Text="📦 Drop to import mod"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <Grid>
                <Path Stroke="{DynamicResource AccentButtonBackground}"
                      StrokeThickness="3"
                      StrokeJoin="Round"
                      Data="M 0,0 L 30,0 M 0,0 L 0,30"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="10,10,0,0" />

                <Path Stroke="{DynamicResource AccentButtonBackground}"
                      StrokeThickness="3"
                      StrokeJoin="Round"
                      Data="M 30,0 L 0,0 M 30,0 L 30,30"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,10,10,0" />

                <Path Stroke="{DynamicResource AccentButtonBackground}"
                      StrokeThickness="3"
                      StrokeJoin="Round"
                      Data="M 0,30 L 30,30 M 0,30 L 0,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Margin="10,0,0,10" />

                <Path Stroke="{DynamicResource AccentButtonBackground}"
                      StrokeThickness="3"
                      StrokeJoin="Round"
                      Data="M 30,30 L 0,30 M 30,30 L 30,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,10,10" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>