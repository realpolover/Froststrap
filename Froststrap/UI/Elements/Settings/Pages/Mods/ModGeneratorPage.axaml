<UserControl x:Class="Froststrap.UI.Elements.Settings.Pages.Mods.ModGeneratorPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:colorpicker="using:ColorPicker"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:ic="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
             xmlns:lucideEnums="clr-namespace:LucideAvalonia.Enum;assembly=LucideAvalonia"
             xmlns:resources="using:Froststrap.Resources"
             xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
             xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings.Mods"
             x:DataType="vm:ModGeneratorViewModel"
             d:DesignHeight="800"
             d:DesignWidth="1100"
             mc:Ignorable="d">

    <ScrollViewer>
        <Grid Margin="14" RowDefinitions="Auto,Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,*,*">
                <controls:CardAction Grid.Column="0" Margin="0,0,4,0"
                                     Command="{Binding OpenCommunityModsCommand}"
                                     Header="{x:Static resources:Strings.Menu_CommunityMods_Title}"
                                     Icon="House"
                                     Description="{x:Static resources:Strings.Menu_CommunityMods_Description}" />

                <controls:CardAction Grid.Column="1" Margin="2,0,2,0"
                                     Command="{Binding OpenPresetModsCommand}"
                                     Header="{x:Static resources:Strings.Menu_PresetMods_Title}"
                                     Icon="BookOpen"
                                     Description="{x:Static resources:Strings.Menu_PresetMods_Description}" />

                <controls:CardAction Grid.Column="2" Margin="4,0,0,0"
                                     Command="{Binding OpenModsCommand}"
                                     Header="{x:Static resources:Strings.Menu_Mods_Title}"
                                     Icon="List"
                                     Description="{x:Static resources:Strings.Menu_Mods_Description}" />
            </Grid>

            <Separator Margin="0,8" Grid.Row="1" />

            <StackPanel Grid.Row="2" Spacing="12">
                <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*">
                        <Grid Grid.Row="0" Margin="0,0,0,12" RowDefinitions="*,Auto">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="{x:Static resources:Strings.Menu_ModGenerator_StylePreview}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock VerticalAlignment="Center"
                                           Text="{x:Static resources:Strings.Menu_ModGenerator_IconSet}"
                                           Margin="0,0,8,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ComboBox Width="200"
                                          ItemsSource="{Binding FontDisplayNames}"
                                          SelectedItem="{Binding SelectedFontDisplayName}" />
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Height="250">
                            <ItemsControl ItemsSource="{Binding GlyphItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Left" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4"
                                                Padding="8"
                                                Width="56"
                                                Height="56"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Viewbox Stretch="Uniform">
                                                <Path Data="{Binding Data}" Fill="{Binding Brush}" Margin="0,0,10,8"/>
                                            </Viewbox>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="Bold" Text="{x:Static resources:Strings.Menu_Appearance_Title}"
                                   Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{x:Static resources:Strings.Common_Angle}" VerticalAlignment="Center" />
                            <NumericUpDown Value="{Binding GradientAngle}"
                                           Width="160"
                                           Minimum="0"
                                           Maximum="360"
                                           FormatString="{}{0}°"
                                           IsEnabled="{Binding IsNotGeneratingMod}"/>
                            <Button Content="{x:Static resources:Strings.Menu_ModGenerator_AddStop}" Command="{Binding AddGradientStopCommand}"
                                    IsEnabled="{Binding IsNotGeneratingMod}"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding GradientStops}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,45,110,Auto,Auto" Margin="0,4" VerticalAlignment="Center"
                                          IsEnabled="{Binding $parent[ItemsControl].DataContext.IsNotGeneratingMod}">
                                        <TextBlock Text="{x:Static resources:Strings.Common_Offset}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="1"
                                                Value="{Binding Offset, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Offset, StringFormat={}{0:N2}}"
                                                   HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="3" Text="{Binding Color, Mode=TwoWay}"
                                                 Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="4" Content="{x:Static resources:Strings.Common_ColorPicker}"
                                                Command="{Binding $parent[ItemsControl].DataContext.OpenColorPickerCommand}"
                                                CommandParameter="{Binding}" Margin="0,0,4,0"/>
                                        <Button Grid.Column="5" Content="{x:Static resources:Strings.Common_Remove}"
                                                Command="{Binding $parent[ItemsControl].DataContext.RemoveGradientStopCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock FontSize="14"
                                   FontWeight="Bold"
                                   Text="{x:Static resources:Strings.Menu_ModGenerator_ModsOptions}"
                                   Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="{x:Static resources:Strings.Menu_ModGenerator_ApplyCursor}" IsChecked="{Binding ColorCursors}" Margin="4,0"
                                      IsEnabled="{Binding IsNotGeneratingMod}"/>
                            <CheckBox Content="{x:Static resources:Strings.Menu_ModGenerator_ApplyShiftlock}" IsChecked="{Binding ColorShiftlock}" Margin="4,0"
                                      IsEnabled="{Binding IsNotGeneratingMod}"/>
                            <CheckBox Content="{x:Static resources:Strings.Menu_ModGenerator_ApplyEmoteWheel}" IsChecked="{Binding ColorEmoteWheel}" Margin="4,0"
                                      IsEnabled="{Binding IsNotGeneratingMod}"/>
                            <CheckBox Content="{x:Static resources:Strings.Menu_ModGenerator_DontColorPlay}" IsChecked="{Binding DontColorPlayIcon}" Margin="4,0"
                                      IsEnabled="{Binding IsNotGeneratingMod}"/>
                            <CheckBox Content="{x:Static resources:Strings.Menu_ModGenerator_IncludeModification}" IsChecked="{Binding IncludeModifications}" Margin="4,0"
                                      IsEnabled="{Binding IsNotGeneratingMod}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{x:Static resources:Strings.Common_Bands}" VerticalAlignment="Center" ToolTip.Tip="{x:Static resources:Strings.Menu_ModGenerator_BandInfo}" />
                                <NumericUpDown Value="{Binding GradientBands}"
                                               Width="100"
                                               Minimum="0"
                                               Maximum="64"
                                               PlaceholderText="8"
                                               ToolTip.Tip="{x:Static resources:Strings.Menu_ModGenerator_BandInfo}"
                                               VerticalAlignment="Center"
                                               IsEnabled="{Binding IsNotGeneratingMod}"/>
                            </StackPanel>
                        </WrapPanel>

                        <Grid ColumnDefinitions="*,*" Margin="0,8,0,8">
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="{x:Static resources:Strings.Menu_ModGenerator_RobloxIcon}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBox Text="{Binding RobloxIconImagePath}" IsReadOnly="True" PlaceholderText="No image selected"
                                             VerticalAlignment="Center" IsEnabled="{Binding IsNotGeneratingMod}"/>
                                    <Button Grid.Column="1" Content="{x:Static resources:Strings.Common_Select}" Command="{Binding SelectRobloxIconCommand}" Margin="4,0,4,0"
                                            IsEnabled="{Binding IsNotGeneratingMod}"/>
                                    <Button Grid.Column="2" Content="{x:Static resources:Strings.Common_Clear}" Command="{Binding ClearRobloxIconCommand}"
                                            IsEnabled="{Binding IsNotGeneratingMod}"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="{x:Static resources:Strings.Menu_ModGenerator_CustomSpinner}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBox Text="{Binding CustomSpinnerPath}" IsReadOnly="True" PlaceholderText="No image selected"
                                             VerticalAlignment="Center" IsEnabled="{Binding IsNotGeneratingMod}"/>
                                    <Button Grid.Column="1" Content="{x:Static resources:Strings.Common_Select}" Command="{Binding SelectSpinnerIconCommand}" Margin="4,0,4,0"
                                            IsEnabled="{Binding IsNotGeneratingMod}"/>
                                    <Button Grid.Column="2" Content="{x:Static resources:Strings.Common_Clear}" Command="{Binding ClearSpinnerIconCommand}"
                                            IsEnabled="{Binding IsNotGeneratingMod}"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{x:Static resources:Strings.Menu_ModGenerator_CustomModName}" FontWeight="SemiBold" Margin="0,8,0,4" IsVisible="{Binding IncludeModifications}"/>
                        <TextBox Text="{Binding ModFolderName, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="{Binding SuggestedFolderName}"
                                 IsVisible="{Binding IncludeModifications}"
                                 IsEnabled="{Binding IsNotGeneratingMod}"
                                 Margin="0,8,0,4"/>
                        <TextBlock Text="{Binding FolderNameValidationError}"
                                   FontSize="12"
                                   IsVisible="{Binding HasFolderNameValidationError}"
                                   Margin="0,0,0,8"/>

                        <Separator Margin="0,12"/>

                        <controls:IconButton Command="{Binding GenerateModCommand}"
                                             IsEnabled="{Binding IsNotGeneratingMod}"
                                             Content="{x:Static resources:Strings.Common_Generate}"
                                             HorizontalAlignment="Stretch"
                                             Height="40"
                                             Icon="Play"
                                             Background="{DynamicResource SystemAccentColor}"
                                             Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                             Classes="accent"/>

                        <TextBlock Text="{Binding StatusText}"
                                   Margin="0,12,0,0"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" />

                        <ProgressBar Value="{Binding Progress}"
                                     Minimum="0"
                                     Maximum="100"
                                     Height="4"
                                     Margin="0,12,0,4"
                                     IsVisible="{Binding IsProgressVisible}"
                                     Classes="accent" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>