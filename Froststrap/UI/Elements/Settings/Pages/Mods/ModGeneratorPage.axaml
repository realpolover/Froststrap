<UserControl x:Class="Froststrap.UI.Elements.Settings.Pages.Mods.ModGeneratorPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:colorpicker="using:ColorPicker"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:ic="using:FluentIcons.Avalonia.Fluent"
             xmlns:resources="using:Froststrap.Resources"
             xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
             xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings.Mods"
             x:DataType="vm:ModGeneratorViewModel"
             d:DesignHeight="800"
             d:DesignWidth="1100"
             mc:Ignorable="d">

    <ScrollViewer>
        <Grid Margin="14" RowDefinitions="Auto,Auto,*">
            <!-- Top card buttons -->
            <Grid Grid.Row="0" ColumnDefinitions="*,*,*">
                <controls:CardAction Grid.Column="0" Margin="0,0,4,0"
                                     Command="{Binding OpenCommunityModsCommand}"
                                     Header="Community Mods"
                                     Icon="ShoppingStore"
                                     Description="Explore user-created mods." />

                <controls:CardAction Grid.Column="1" Margin="2,0,2,0"
                                     Command="{Binding OpenPresetModsCommand}"
                                     Header="Preset Mods"
                                     Icon="BookOpen"
                                     Description="Official built-in mods." />

                <controls:CardAction Grid.Column="2" Margin="4,0,0,0"
                                     Command="{Binding OpenModsCommand}"
                                     Header="My Mods"
                                     Icon="TextBulletList"
                                     Description="Manage your active mods." />
            </Grid>

            <Separator Margin="0,8" Grid.Row="1" />

            <StackPanel Grid.Row="2" Spacing="12">
                <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*">
                        <Grid Grid.Row="0" Margin="0,0,0,12" RowDefinitions="*,Auto">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Style Preview"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock VerticalAlignment="Center"
                                           Text="Icon Set:"
                                           Margin="0,0,8,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ComboBox Width="200"
                                          ItemsSource="{Binding FontDisplayNames}"
                                          SelectedItem="{Binding SelectedFontDisplayName}" />
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Height="250">
                            <ItemsControl ItemsSource="{Binding GlyphItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Left" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4"
                                                Padding="8"
                                                Width="56"
                                                Height="56"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Viewbox Stretch="Uniform">
                                                <Path Data="{Binding Data}" Fill="{Binding ColorBrush}" Margin="0,0,10,8"/>
                                            </Viewbox>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="Bold" Text="Appearance"
                                   Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal" Spacing="4">
                            <Button Content="Add Stop" Command="{Binding AddGradientStopCommand}"/>
                            <TextBlock Text="Angle:" VerticalAlignment="Center" />
                            <NumericUpDown Value="{Binding GradientAngle}"
                                           Width="160"
                                           Minimum="0"
                                           Maximum="360"
                                           FormatString="{}{0}°"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding GradientStops}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,45,110,Auto,Auto" Margin="0,4" VerticalAlignment="Center">
                                        <TextBlock Text="Offset:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="1"
                                                Value="{Binding Offset, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Offset, StringFormat={}{0:N2}}"
                                                   HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="3" Text="{Binding Color, Mode=TwoWay}"
                                                 Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="4" Content="Pick"
                                                Command="{Binding $parent[ItemsControl].DataContext.OpenColorPickerCommand}"
                                                CommandParameter="{Binding}" Margin="0,0,4,0"/>
                                        <Button Grid.Column="5" Content="Remove"
                                                Command="{Binding $parent[ItemsControl].DataContext.RemoveGradientStopCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock FontSize="14"
                                   FontWeight="Bold"
                                   Text="Mod Options"
                                   Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Apply to Cursors" IsChecked="{Binding ColorCursors}" Margin="4,0"/>
                            <CheckBox Content="Apply to Shiftlock" IsChecked="{Binding ColorShiftlock}" Margin="4,0"/>
                            <CheckBox Content="Apply to Emote Wheel" IsChecked="{Binding ColorEmoteWheel}" Margin="4,0"/>
                            <CheckBox Content="Auto add to My Mods" IsChecked="{Binding IncludeModifications}" Margin="4,0"/>
                        </StackPanel>

                        <Separator Margin="0,12"/>

                        <Button Command="{Binding GenerateModCommand}"
                                IsEnabled="{Binding IsNotGeneratingMod}"
                                Content="Generate Mod"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                Background="{DynamicResource SystemAccentColor}"
                                Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                Classes="accent">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <ic:SymbolIcon Foreground="{DynamicResource TextFillColorPrimaryBrush}" Symbol="PlayCircle" />
                                        <TextBlock Text="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <TextBlock Text="{Binding StatusText}"
                                   Margin="0,12,0,0"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" />

                        <ProgressBar Value="{Binding Progress}"
                                     Minimum="0"
                                     Maximum="100"
                                     Height="4"
                                     Margin="0,12,0,4"
                                     IsVisible="{Binding IsProgressVisible}"
                                     Classes="accent" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>