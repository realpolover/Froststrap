<UserControl
    x:Class="Froststrap.UI.Elements.Settings.Pages.BehaviourPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="using:Froststrap.Resources"
    xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:gv="using:Froststrap.UI.ViewModels"
    xmlns:ic="using:FluentIcons.Avalonia.Fluent"
    d:DesignHeight="2500"
    d:DesignWidth="1200"
    x:DataType="vm:BehaviourViewModel"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="14">
            <controls:OptionControl
                Header="{x:Static resources:Strings.Menu_Behaviour_ConfirmLaunches_Title}"
                Description="{x:Static resources:Strings.Menu_Behaviour_ConfirmLaunches_Description}">
                <ToggleSwitch IsChecked="{Binding ConfirmLaunches, Mode=TwoWay}" />
            </controls:OptionControl>

            <controls:OptionControl
                Header="{x:Static resources:Strings.Menu_Behaviour_CloseCrashHandler_Title}"
                Description="{x:Static resources:Strings.Menu_Behaviour_CloseCrashHandler_Description}"
                IsVisible="{x:Static gv:GlobalViewModel.IsWindows}">
                <ToggleSwitch IsChecked="{Binding CloseCrashHandler, Mode=TwoWay}" />
            </controls:OptionControl>

            <ui:InfoBar IsOpen="True" Severity="Warning" Message="{x:Static resources:Strings.Menu_Integrations_MultiInstanceLaunching_Warning}" />

            <controls:CardExpander
                Header="{x:Static resources:Strings.Menu_Behaviour_MultiInstances_Title}"
                Description="{x:Static resources:Strings.Menu_Behaviour_MultiInstances_Description}"
                IsExpanded="{Binding MultiInstances, Mode=OneWay}"
                Classes="NoUserExpansion">
                <controls:CardExpander.HeaderContent>
                    <ToggleSwitch IsChecked="{Binding MultiInstances, Mode=TwoWay}" />
                </controls:CardExpander.HeaderContent>

                <StackPanel Margin="0,8,0,0">
                    <controls:OptionControl
                        Description="Automatically fixes error code 773 when teleporting between games with multiple accounts."
                        Header="Teleport Fix">
                        <ToggleSwitch IsChecked="{Binding Error773Fix, Mode=TwoWay}" />
                    </controls:OptionControl>
                </StackPanel>
            </controls:CardExpander>

            <controls:OptionControl
                Header="{x:Static resources:Strings.Menu_Behaviour_BackgroundUpdates_Title}"
                Description="{x:Static resources:Strings.Menu_Behaviour_BackgroundUpdates_Description}"
                IsVisible="{x:Static gv:GlobalViewModel.IsWindows}">
                <ToggleSwitch IsChecked="{Binding BackgroundUpdates, Mode=TwoWay}" />
            </controls:OptionControl>

            <controls:OptionControl
                Header="{x:Static resources:Strings.Menu_Behaviour_ProcessPriority_Title}"
                Description="{x:Static resources:Strings.Menu_Behaviour_ProcessPriority_Description}"
                IsVisible="{x:Static gv:GlobalViewModel.IsWindows}">
                <ComboBox
                    MinWidth="200"
                    ItemsSource="{Binding ProcessPriorityOptions}"
                    SelectedItem="{Binding SelectedPriority, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumNameConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </controls:OptionControl>

            <controls:CardExpander Header="Experimental" Description="A collection of experimental settings. Be careful while using them, as they may or may not work as intended." IsExpanded="True">
                <StackPanel>
                    <controls:OptionControl
                        Header="{x:Static resources:Strings.Menu_Behaviour_AllowCookieAccess_Title}"
                        Description="{Binding Source={x:Static resources:Strings.Menu_Behaviour_AllowCookieAccess_Description}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://github.com/fishstrap/fishstrap/wiki/Account-Access#what-will-fishstrap-access-with-your-account'}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="Warning" VerticalAlignment="Center" Foreground="Orange">
                                <ic:SymbolIcon.Styles>
                                    <Style Selector="ic|SymbolIcon">
                                        <Setter Property="IsVisible" Value="False"/>
                                    </Style>
                                    <Style Selector="ic|SymbolIcon">
                                        <Style.Resources>
                                        </Style.Resources>
                                        <Setter Property="IsVisible" Value="{Binding CookieLoadingFailed}"/>
                                    </Style>
                                </ic:SymbolIcon.Styles>
                            </ic:SymbolIcon>
                            <ToggleSwitch IsChecked="{Binding CookieAccess, Mode=TwoWay}" />
                        </StackPanel>
                    </controls:OptionControl>

                    <controls:OptionControl
                        Header="{x:Static resources:Strings.Bootstrapper_Experimental_BetterMatchmaking_Title}"
                        Description="{x:Static resources:Strings.Bootstrapper_Experimental_BetterMatchmaking_Description}">
                        <StackPanel Orientation="Horizontal">
                            <ic:SymbolIcon Symbol="Warning" VerticalAlignment="Center" Foreground="Orange">
                                <ic:SymbolIcon.Styles>
                                    <Style Selector="ic|SymbolIcon">
                                        <Setter Property="IsVisible" Value="False"/>
                                    </Style>
                                    <Style Selector="ic|SymbolIcon">
                                        <Style.Resources>
                                        </Style.Resources>
                                        <Setter Property="IsVisible" Value="{Binding CookieLoadingFailed}"/>
                                    </Style>
                                </ic:SymbolIcon.Styles>
                            </ic:SymbolIcon>
                            <ToggleSwitch IsChecked="{Binding EnableBetterMatchmaking, Mode=TwoWay}" />
                        </StackPanel>
                    </controls:OptionControl>

                    <controls:OptionControl
                        Header="{x:Static resources:Strings.Bootstrapper_Experimental_BetterMatchmaking_RandomizeServer_Title}"
                        Description="{x:Static resources:Strings.Bootstrapper_Experimental_BetterMatchmaking_RandomizeServer_Description}">
                        <StackPanel Orientation="Horizontal">
                            <ic:SymbolIcon Symbol="Warning" VerticalAlignment="Center" Foreground="Orange">
                                <ic:SymbolIcon.Styles>
                                    <Style Selector="ic|SymbolIcon">
                                        <Setter Property="IsVisible" Value="False"/>
                                    </Style>
                                    <Style Selector="ic|SymbolIcon">
                                        <Style.Resources>
                                        </Style.Resources>
                                        <Setter Property="IsVisible" Value="{Binding CookieLoadingFailed}"/>
                                    </Style>
                                </ic:SymbolIcon.Styles>
                            </ic:SymbolIcon>
                            <ToggleSwitch IsChecked="{Binding EnableBetterMatchmakingRandomization, Mode=TwoWay}" />
                        </StackPanel>
                    </controls:OptionControl>
                </StackPanel>
            </controls:CardExpander>

            <controls:CardExpander
                Header="App Storage Settings"
                Description="Configure internal Roblox application settings stored."
                IsVisible="{Binding IsAppStorageVisible}"
                IsExpanded="True">

                <StackPanel Margin="0,8,0,0">

                    <controls:OptionControl
                        Header="Roblox App Theme"
                        Description="Changes the visual theme for Roblox."
                        IsVisible="{Binding ShowTheme}">
                        <ComboBox
                            MinWidth="200"
                            ItemsSource="{Binding AppThemeOptions}"
                            SelectedItem="{Binding SelectedTheme, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </controls:OptionControl>

                    <controls:OptionControl
                        Header="Launch at Startup"
                        Description="Automatically launch the Roblox app when you start your PC."
                        IsVisible="{Binding ShowLaunchAtStartup}">
                        <ToggleSwitch IsChecked="{Binding LaunchAtStartup, Mode=TwoWay}" />
                    </controls:OptionControl>

                    <controls:OptionControl
                        Header="Minimize to Tray"
                        Description="Sends the app to the system tray instead of closing it fully."
                        IsVisible="{Binding ShowMinimizeToTray}">
                        <ToggleSwitch IsChecked="{Binding MinimizeToTray, Mode=TwoWay}" />
                    </controls:OptionControl>

                    <controls:OptionControl
                        Header="System Tray Modal"
                        Description="Controls whether the tray informational modal is suppressed."
                        IsVisible="{Binding ShowSystemTrayModal}">
                        <ToggleSwitch IsChecked="{Binding SystemTrayModalShown, Mode=TwoWay}" />
                    </controls:OptionControl>
                </StackPanel>
            </controls:CardExpander>

            <controls:CardExpander
                IsExpanded="True"
                Header="{x:Static resources:Strings.Menu_Bootstrapper_CleanUp_Title}"
                Description="{x:Static resources:Strings.Menu_Bootstrapper_CleanUp_Description}">
                <StackPanel>
                    <controls:OptionControl
                        Header="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Age_Title}"
                        Description="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Age_Description}">
                        <ComboBox MinWidth="200" ItemsSource="{Binding CleanerOptions}" SelectedItem="{Binding CleanerOption, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumNameConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </controls:OptionControl>
                    <controls:OptionControl
                        Header="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Cache_Title}"
                        Description="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Cache_Description}">
                        <ToggleSwitch IsChecked="{Binding CleanerCache, Mode=TwoWay}" />
                    </controls:OptionControl>
                    <controls:OptionControl
                        Header="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Logs_Title}"
                        Description="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Logs_Description}">
                        <ToggleSwitch IsChecked="{Binding CleanerLogs, Mode=TwoWay}" />
                    </controls:OptionControl>
                    <controls:OptionControl
                        Header="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_IncludeBloxstrap_Title}"
                        Description="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_IncludeBloxstrap_Description}">
                        <ToggleSwitch IsChecked="{Binding CleanerFroststrap, Mode=TwoWay}" />
                    </controls:OptionControl>
                </StackPanel>
            </controls:CardExpander>
        </StackPanel>
    </ScrollViewer>
</UserControl>