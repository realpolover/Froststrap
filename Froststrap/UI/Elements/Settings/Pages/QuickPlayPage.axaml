<UserControl
    x:Class="Froststrap.UI.Elements.Settings.Pages.QuickPlayPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lucideAvalonia="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
    xmlns:resources="using:Froststrap.Resources"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
    xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
    xmlns:ic="using:FluentIcons.Avalonia.Fluent"
    x:DataType="vm:ShortcutsViewModel">

    <ScrollViewer>
        <StackPanel Margin="14">

        </StackPanel>
    </ScrollViewer>
</UserControl>
