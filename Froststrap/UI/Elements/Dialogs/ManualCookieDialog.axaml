<base:AvaloniaWindow x:Class="Froststrap.UI.Elements.Dialogs.ManualCookieDialog"
                     xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:ui="using:FluentAvalonia.UI.Controls"
                     xmlns:resources="clr-namespace:Froststrap.Resources"
                     xmlns:ic="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
                     xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Dialogs"
                     xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
                     x:DataType="vm:ManualCookieDialogViewModel"
                     Width="500"
                     Height="475"
                     CanResize="True"
                     WindowStartupLocation="CenterOwner"
                     mc:Ignorable="d">

    <Grid Background="{DynamicResource ApplicationBackgroundColor}" RowDefinitions="Auto,*,Auto">
        <controls:TitleBar
            Title="{x:Static resources:Strings.Menu_ManualLogin_Title}"
            Grid.Row="0"
            ShowMaximize="False"
            Icon="avares://Froststrap/Froststrap.ico"
            KeyboardNavigation.TabNavigation="None"
            ShowMinimize="False" />

        <Grid Grid.Row="1" Margin="20,8,20,16" RowDefinitions="Auto,Auto,Auto,Auto">
            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,16"
                Orientation="Horizontal">
                <ic:Lucide
                    Margin="0,0,8,0"
                    FontSize="20"
                    Icon="Link2" />
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{x:Static resources:Strings.Menu_ManualLogin_Title}" />
            </StackPanel>

            <Border
                Grid.Row="2"
                Margin="0,0,0,12"
                Padding="16,12"
                Background="{DynamicResource PrimaryBackgroundColor}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="{x:Static resources:Strings.Menu_ManualLogin_PasteSecurity}" />

                    <TextBox
                        x:Name="CookieTextBox"
                        Grid.Row="1"
                        Height="65"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        Text="{Binding CookieInput, UpdateSourceTrigger=PropertyChanged}"
                        FontFamily="Consolas"
                        FontSize="12" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="3" Margin="8,0,0,0">
                <TextBlock Margin="0,2,0,2">
                    <Run Text="1." FontWeight="Bold" />
                    <Run Text="{x:Static resources:Strings.Menu_ManualLogin_Instruction_1}" />
                </TextBlock>
                <TextBlock Margin="0,2,0,2">
                    <Run Text="2." FontWeight="Bold" />
                    <Run Text="{x:Static resources:Strings.Menu_ManualLogin_Instruction_2}" />
                </TextBlock>
                <TextBlock Margin="0,2,0,2">
                    <Run Text="3." FontWeight="Bold" />
                    <Run Text="{x:Static resources:Strings.Menu_ManualLogin_Instruction_3}" />
                </TextBlock>
                <TextBlock Margin="0,2,0,2">
                    <Run Text="4." FontWeight="Bold" />
                    <Run Text="{x:Static resources:Strings.Menu_ManualLogin_Instruction_4}" />
                </TextBlock>
                <TextBlock Margin="0,2,0,2">
                    <Run Text="5." FontWeight="Bold" />
                    <Run Text="{x:Static resources:Strings.Menu_ManualLogin_Instruction_5}" />
                </TextBlock>
                <TextBlock Margin="0,2,0,2">
                    <Run Text="6." FontWeight="Bold" />
                    <Run Text="{x:Static resources:Strings.Menu_ManualLogin_Instruction_6}" />
                </TextBlock>
                <TextBlock Margin="0,2,0,2">
                    <Run Text="7." FontWeight="Bold" />
                    <Run Text="{x:Static resources:Strings.Menu_ManualLogin_Instruction_7}" />
                </TextBlock>
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="2"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="0,1,0,0">
            <Grid Margin="20,16" ColumnDefinitions="*,Auto,Auto">
                <Rectangle Grid.Column="0" Fill="Transparent" />

                <Button x:Name="AddButton"
                        Grid.Column="1"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Right"
                        Command="{Binding AddAccountCommand}"
                        Content="{x:Static resources:Strings.Common_Add}"
                        IsEnabled="{Binding IsAddEnabled}"/>

                <Button
                    Grid.Column="2"
                    MinWidth="100"
                    HorizontalAlignment="Right"
                    Command="{Binding CancelCommand}"
                    Content="{x:Static resources:Strings.Common_Cancel}"/>
            </Grid>
        </Border>
    </Grid>
</base:AvaloniaWindow>