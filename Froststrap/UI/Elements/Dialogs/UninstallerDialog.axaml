<base:AvaloniaWindow
    x:Class="Froststrap.UI.Elements.Dialogs.UninstallerDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
    xmlns:resources="using:Froststrap.Resources"
    xmlns:ic="using:IconPacks.Avalonia.Material"
    xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Dialogs"
    xmlns:pages="clr-namespace:Froststrap.UI.Elements.Installer.Pages"
    Title="{x:Static resources:Strings.Menu_Title}"
    MinWidth="0" MinHeight="0" Width="480"
    SizeToContent="Height"
    x:DataType="vm:UninstallerViewModel"
    WindowStartupLocation="CenterScreen">

    <Grid Background="{DynamicResource ApplicationBackgroundColor}" RowDefinitions="Auto,*,Auto">
        <controls:TitleBar Grid.Row="0" Grid.ColumnSpan="2" Title="Froststrap" ShowMinimize="False" ShowMaximize="False" Icon="avares://Froststrap/Froststrap.ico" />

        <StackPanel Grid.Row="1" Margin="12">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Static resources:Strings.Uninstaller_Title}" />
            <controls:MarkdownTextBlock FontSize="14" Margin="0,0,0,16" MarkdownText="{Binding Text, Mode=OneTime}" TextWrapping="Wrap" />
            <CheckBox Content="{x:Static resources:Strings.Uninstaller_KeepData_Label}" IsChecked="{Binding KeepData, Mode=TwoWay}" />
            <TextBlock FontSize="14" Text="{x:Static resources:Strings.Uninstaller_KeepData_Description}" TextWrapping="Wrap" IsVisible="{Binding KeepData, Mode=OneWay}"/>
        </StackPanel>

        <Border Grid.Row="2" Margin="0,10,0,0" Padding="15" Background="{DynamicResource PrimaryBackgroundColor}">
            <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight" HorizontalAlignment="Right">
                <Button MinWidth="100" Content="{x:Static resources:Strings.Uninstaller_Uninstall}" Command="{Binding ConfirmUninstallCommand}"  />
                <Button MinWidth="100" Margin="12,0,0,0" Content="{x:Static resources:Strings.Common_Cancel}" Command="{Binding CancelCommand}"  />
            </StackPanel>
        </Border>
    </Grid>
</base:AvaloniaWindow>
