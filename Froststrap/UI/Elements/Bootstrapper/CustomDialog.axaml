<base:AvaloniaDialogBase xmlns="https://github.com/avaloniaui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         xmlns:base="clr-namespace:Froststrap.UI.Elements.Bootstrapper.Base"
                         xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
                         mc:Ignorable="d"
                         x:Class="Froststrap.UI.Elements.Bootstrapper.CustomDialog"
                         Title="Froststrap"
                         Width="800"
                         Height="450"
                         MinWidth="150"
                         MinHeight="150"
                         MaxWidth="3000"
                         MaxHeight="3000"
                         CanResize="False"
                         WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*">
        <controls:TitleBar
            x:Name="RootTitleBar"
            Title="Froststrap"
            Grid.Row="0"
            ZIndex="1001"
            ShowClose="False"
            ShowMaximize="False"
            ShowMinimize="False" />
        <Grid x:Name="ElementGrid" Grid.Row="1" />
    </Grid>
</base:AvaloniaDialogBase>