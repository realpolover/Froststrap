<base:AvaloniaWindow xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:pages="clr-namespace:Froststrap.UI.Elements.About.Pages"
                     xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
                     xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
                     xmlns:resources="clr-namespace:Froststrap.Resources"
                     xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.About"
                     xmlns:ui="using:FluentAvalonia.UI.Controls"
                     xmlns:ic="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
                     mc:Ignorable="d"
                     x:Class="Froststrap.UI.Elements.About.MainWindow"
                     x:DataType="vm:MainWindowViewModel"
                     Title="{x:Static resources:Strings.About_Title}"
                     MinWidth="740" Width="740" Height="440"
                     WindowStartupLocation="CenterScreen" CanResize="True">

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource ApplicationBackgroundColor}">
        <controls:TitleBar Grid.Row="0" Background="{DynamicResource LayerFillColorDefaultBrush}"
                           Title="{x:Static resources:Strings.About_Title}"
                           Icon="avares://Froststrap/Froststrap.ico" />

        <Grid Grid.Row="1" Name="MainGrid">
            <ui:NavigationView Name="NavView"
                               IsPaneOpen="False"
                               PaneDisplayMode="LeftCompact"
                               IsSettingsVisible="False"
                               IsBackButtonVisible="False"
                               OpenPaneLength="140"
                               ItemInvoked="NavView_ItemInvoked">
                <ui:NavigationView.Styles>
                    <Style Selector="ui|NavigationView /template/ ScrollViewer#MenuItemsScrollViewer">
                        <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>
                    </Style>
                </ui:NavigationView.Styles>
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Tag="about">
                        <ui:NavigationViewItem.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:Lucide Icon="Info" Width="16" Height="16" />
                                <TextBlock Text="{x:Static resources:Strings.Menu_About_Title}" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:NavigationViewItem.Content>
                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Tag="licenses">
                        <ui:NavigationViewItem.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:Lucide Icon="Book" Width="16" Height="16" />
                                <TextBlock Text="{x:Static resources:Strings.About_Licenses_Title}" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:NavigationViewItem.Content>
                    </ui:NavigationViewItem>
                </ui:NavigationView.MenuItems>

                <ui:NavigationView.Content>
                    <TransitioningContentControl
                        x:Name="PageContentControl"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{DynamicResource LayerFillColorDefaultBrush}" />
                </ui:NavigationView.Content>
            </ui:NavigationView>
        </Grid>
    </Grid>
</base:AvaloniaWindow>