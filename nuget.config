<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <!-- Disable PackageSourceMapping globally -->
    <add key="enablePackageSourceMapping" value="false" />
  </config>
  <packageSources>
    <clear />
    <add key="nuget" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>